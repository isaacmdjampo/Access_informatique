# ============================================================
# Access Informatique — Frontend Apache (.htaccess)
# À placer à la racine du dossier dist/ après "npm run build"
# ============================================================
# Vue Router utilise l'API HTML5 History (createWebHistory).
# Sans ce fichier, les rechargements de page donnent une 404
# car Apache cherche un fichier physique au lieu de déléguer
# à index.html.
# ============================================================

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Si le fichier ou dossier physique existe, le servir directement
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Toutes les autres URL → index.html (Vue Router prend le relai)
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# ── En-têtes de sécurité ──────────────────────────────────────
<IfModule mod_headers.c>
  # Empêche le navigateur de deviner le type MIME
  Header always set X-Content-Type-Options "nosniff"

  # Interdit l'inclusion dans un <iframe> (clickjacking)
  Header always set X-Frame-Options "SAMEORIGIN"

  # Active le filtre XSS du navigateur
  Header always set X-XSS-Protection "1; mode=block"

  # Politique de référent stricte
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Désactive l'accès aux fonctionnalités sensibles du navigateur
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # Cache des assets versionnés (js, css, images) — 1 an
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|webp|svg|woff2|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Ne jamais cacher index.html
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
