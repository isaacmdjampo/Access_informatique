# ============================================================
# ACCESS INFORMATIQUE — CONFIGURATION ENVIRONNEMENT
# NE PAS VERSIONNER CE FICHIER (.gitignore)
# Copier en .env et remplir les valeurs réelles
# ============================================================

# ---- Application ----
APP_ENV=development
APP_URL=http://localhost/Access_Informatique/backend

# ---- Base de données ----
DB_HOST=127.0.0.1
DB_NAME=access_informatique
DB_USER=root
DB_PASS=

# ---- JWT (changer en production !) ----
JWT_SECRET=access_informatique_super_secret_key_change_in_production_2024
JWT_EXPIRY=3600

# ---- Mailer (SMTP) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre@gmail.com
MAIL_PASSWORD=votre_mot_de_passe_application
MAIL_FROM=noreply@accessinformatique.com
MAIL_FROM_NAME=Access Informatique
MAIL_ADMIN=admin@accessinformatique.com

# ---- Frontend (CORS) ----
FRONTEND_URL=http://localhost:5173

# ---- Uploads ----
UPLOAD_URL=http://localhost/Access_Informatique/backend/uploads
